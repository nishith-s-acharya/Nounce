{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist/worker",
    "rootDir": "./src/lib/executor",
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/lib/executor/**/*.ts"],
  "exclude": ["node_modules"]
}
